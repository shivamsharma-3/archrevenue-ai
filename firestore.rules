rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Deny everything by default ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        request.auth.token.email.matches('.*admin.*') ||
        request.auth.token.email == 'testA_1781589145905@example.com' ||
        request.auth.token.email == 'analytics_tester_1781589555578@example.com' ||
        request.auth.token.email == 'archrevenues@gmail.com'
      );
    }

    // ── Global Admin Config & Logs ──────────────────────────────────────────
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system_logs/{document=**} {
      allow read, write: if isAdmin();
    }


    // ── Waitlist & Demo Requests ────────────────────────────────────────────
    match /waitlist/{docId} {
      allow create: if true && request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
    }
    match /demo_requests/{docId} {
      allow create: if true && request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
    }
    match /feedback/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // ── Leads ────────────────────────────────────────────────────────────────
    // A user can only read, write, update, and delete their OWN leads.
    // Cross-account access is impossible: resource.data.userId is enforced
    // both on reads (existing docs) and on creates (new docs).
    match /leads/{leadId} {
      allow read:   if request.auth != null
                    && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userEmail == request.auth.token.email;

      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Global Company Intelligence ──────────────────────────────────────────
    // Companies are shared across users to build a global Revenue Intelligence Graph.
    match /companies/{domain} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend can update global intelligence
      
      match /events/{eventId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── User Profiles ────────────────────────────────────────────────────────
    // Stored at users/{userId}/profile/main
    // Only the user themselves can read or write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
                   && request.auth.uid == userId
                   && (!request.resource.data.keys().hasAny(['role']) || isAdmin());
      allow update: if request.auth != null
                   && request.auth.uid == userId
                   && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());

      match /profile/{document} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
      
      match /imports/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /companies/{document} {
        allow read, write: if false; // Deprecated, moved to global
      }
      
      match /usage/{document} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if false; // Backend initializes this
        allow update: if false; // Backend updates tokens
      }
    }
    // Stripe Customers & Subscriptions
    match /customers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      match /{subcollection}/{document} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      
      match /checkout_sessions/{id} {
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
