# ──────────────────────────────────────────────────────────────────────────────
# PUBLIC VARIABLES (Client-side Vite bundle)
# ──────────────────────────────────────────────────────────────────────────────

# Vite automatically injects these into the browser bundle.
# ONLY put public, non-secret keys here.
VITE_FIREBASE_API_KEY="your_public_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_firebase_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_SENTRY_DSN="your_sentry_dsn"
VITE_POSTHOG_KEY="your_posthog_key"
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_STRIPE_PUBLIC_KEY="your_stripe_public_key"

# ──────────────────────────────────────────────────────────────────────────────
# PRIVATE VARIABLES (Backend Functions / Node.js only)
# ──────────────────────────────────────────────────────────────────────────────

# NEVER prefix these with VITE_.
# These must only be configured in your deployment environment (Vercel/Firebase Functions).
GROQ_API_KEY="your_groq_api_key"
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="your_firebase_client_email"
FIREBASE_PRIVATE_KEY="your_firebase_private_key"

# OTP Email (Resend — https://resend.com)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Sender address shown to users. Use 'onboarding@resend.dev' for testing,
# or set to 'noreply@yourdomain.com' after verifying your domain in Resend.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Gemini AI — paid user tier (aistudio.google.com)
# Free users automatically use Groq. Paid users (Starter/Pro) use Gemini 2.5 Flash.
GEMINI_API_KEY="AQ.xxxxxxxxxxxxxxxxxxxx"


